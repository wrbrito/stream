{
  "name": "stream-backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx --watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "prisma": "prisma",
    "migrate": "prisma migrate dev --name init",
    "seed": "tsx prisma/seed.ts",
    "db:seed": "prisma db seed",
    "test": "vitest run"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@distube/ytdl-core": "^4.16.12",
    "@prisma/client": "5.8.0",
    "bcryptjs": "2.4.3",
    "cors": "2.8.5",
    "dotenv": "16.3.1",
    "express": "4.18.2",
    "ffmpeg-static": "5.1.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "2.1.2",
    "jsonwebtoken": "9.0.2",
    "multer": "1.4.5-lts.1",
    "youtube-dl-exec": "^3.1.6",
    "ytdl-core": "^4.11.5",
    "zod": "3.23.2"
  },
  "devDependencies": {
    "@prisma/client": "5.8.0",
    "@types/bcryptjs": "2.4.2",
    "@types/cors": "2.8.13",
    "@types/express": "4.17.17",
    "@types/jsonwebtoken": "9.0.2",
    "@types/multer": "1.4.7",
    "@types/node": "^20.14.2",
    "prisma": "5.8.0",
    "supertest": "6.3.4",
    "ts-node": "^10.9.2",
    "tsx": "^4.0.0",
    "typescript": "^5.6.2",
    "vitest": "1.5.0"
  }
}
