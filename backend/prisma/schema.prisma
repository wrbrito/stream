generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// VideoTipo substituído por String


// VideoStatus substituído por String


// ProcessamentoStatus substituído por String


model Usuario {
  id         Int       @id @default(autoincrement())
  nome       String
  email      String    @unique
  senha      String
  perfil     String @default("ALUNO")
  ativo      Boolean   @default(true)
  podeComentar Boolean @default(true)
  fotoPerfil String?
  criadoEm   DateTime  @default(now())
  videos     Video[]
  visualizacoes Visualizacao[]
  favoritos  Favorito[]
  comentarios Comentario[]
  avaliacoes  Avaliacao[]
  notificacoes Notification[]
}

model Categoria {
  id         Int      @id @default(autoincrement())
  nome       String   @unique
  descricao  String?
  slug       String   @unique
  criadoEm   DateTime @default(now())
  videos     Video[]
}

model Tag {
  id      Int      @id @default(autoincrement())
  nome    String   @unique
  videos  Video[]

  @@index([nome])
}

model Video {
  id            Int          @id @default(autoincrement())
  titulo        String
  descricao     String
  autor         String
  tipo          String @default("INTERNO")
  status        String @default("PENDENTE")
  urlOriginal   String?
  caminhoArquivo String?
  miniatura     String?
  criadoEm      DateTime     @default(now())
  atualizadoEm   DateTime     @updatedAt
  categoria      Categoria    @relation(fields: [categoriaId], references: [id])
  categoriaId    Int
  uploader       Usuario      @relation(fields: [uploaderId], references: [id])
  uploaderId     Int
  visualizacoes  Visualizacao[]
  favoritos      Favorito[]
  comentarios    Comentario[]
  avaliacoes     Avaliacao[]
  processamento  Processamento?
  tags           Tag[]

  @@index([categoriaId])
  @@index([status, criadoEm])
  @@index([status, categoriaId]) // Para recomendações relacionadas
  @@index([criadoEm]) // Para recência
  @@index([status]) // Para filtrar vídeos ativos
}

model Visualizacao {
  id             Int      @id @default(autoincrement())
  usuario        Usuario? @relation(fields: [usuarioId], references: [id])
  usuarioId      Int?
  video          Video    @relation(fields: [videoId], references: [id])
  videoId        Int
  tempoAssistido Int      @default(0) // Tempo em segundos
  data           DateTime @default(now())

  @@index([usuarioId])
  @@index([data])
  @@index([videoId])
  @@index([usuarioId, videoId])
  @@index([usuarioId, data])
  @@index([data, videoId]) // Para trending por período
  @@index([videoId, data]) // Para agregações por vídeo
}

model Favorito {
  id        Int      @id @default(autoincrement())
  usuario   Usuario  @relation(fields: [usuarioId], references: [id])
  usuarioId Int
  video     Video    @relation(fields: [videoId], references: [id])
  videoId   Int
  criadoEm  DateTime @default(now())

  @@unique([usuarioId, videoId])
  @@index([videoId])
  @@index([criadoEm])
  @@index([usuarioId, criadoEm]) // Para afinidade por usuário
}

model Processamento {
  id            Int                 @id @default(autoincrement())
  video         Video               @relation(fields: [videoId], references: [id])
  videoId       Int                 @unique
  status        String @default("PENDENTE")
  mensagem      String?
  progresso     Int                 @default(0)
  iniciadoEm    DateTime            @default(now())
  finalizadoEm  DateTime?
}

model Notification {
  id        Int      @id @default(autoincrement())
  titulo    String
  mensagem  String
  usuarioId Int?
  usuario   Usuario? @relation(fields: [usuarioId], references: [id])
  lida      Boolean  @default(false)
  criadoEm  DateTime @default(now())
}

model Configuracao {
  id    Int    @id @default(autoincrement())
  chave String @unique
  valor String
}

model Comentario {
  id        Int      @id @default(autoincrement())
  texto     String
  usuario   Usuario  @relation(fields: [usuarioId], references: [id])
  usuarioId Int
  video     Video    @relation(fields: [videoId], references: [id])
  videoId   Int
  parentId  Int?
  parent    Comentario?  @relation("Respostas", fields: [parentId], references: [id])
  respostas Comentario[] @relation("Respostas")
  criadoEm  DateTime @default(now())
}

model Avaliacao {
  id        Int      @id @default(autoincrement())
  nota      Int
  usuario   Usuario  @relation(fields: [usuarioId], references: [id])
  usuarioId Int
  video     Video    @relation(fields: [videoId], references: [id])
  videoId   Int
  criadoEm  DateTime @default(now())

  @@unique([usuarioId, videoId])
}
